"""
slurm_tui.py — A zero-config Slurm terminal UI

Usage:
    uv run slurm_tui.py          # explicit
    ./slurm_tui.py               # if chmod +x (shebang handles it)

Keys:
    1  →  My Jobs        (squeue --me)
    2  →  Free Nodes     (sinfo --format=...)
    3  →  Job Efficiency (calls the `efficiency` script)
    r  →  Force refresh
    q  →  Quit
"""

